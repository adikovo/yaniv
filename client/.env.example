# Client environment variables (Vite, build-time)
#
# Copy to `.env` for a local override. In production these are set in
# Netlify (Site settings -> Environment), NOT in a committed file.
#
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# Base URL of the Yaniv server (no trailing slash).
# - Unset locally        -> client falls back to http://localhost:3000
# - Production (Netlify)  -> must be https://, e.g. https://yaniv-xyz.duckdns.org
VITE_SERVER_URL=
