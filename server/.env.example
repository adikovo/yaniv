# Server environment variables (runtime)
#
# Copy to `.env` on the host (the VM). Never commit a real `.env`.

# Comma-separated browser origins allowed to connect (CORS + Socket.io).
# - Unset       -> defaults to local dev origin (http://localhost:5173)
# - Production  -> the deployed client origin, e.g. https://yaniv-card-game.netlify.app
# Do NOT use "*" in production.
CLIENT_ORIGIN=

# Port the server listens on. nginx proxies to 127.0.0.1:$PORT. Defaults to 3000.
PORT=3000
